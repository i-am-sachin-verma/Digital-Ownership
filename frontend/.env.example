# Digital Ownership dApp Environment Variables Template
# Copy this file to '.env' and fill in your details

# The RPC provider URL to connect to the Ethereum Network (e.g. Infura, Alchemy, or Local Anvil)
VITE_RPC_PROVIDER_URL=http://127.0.0.1:8545

# Smart Contract Addresses
VITE_SOVEREIGN_IDENTITY_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
VITE_ACCESS_CONTROLLER_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
VITE_ENDORSEMENT_MANAGER_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
VITE_DAO_EXECUTOR_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

# Optional features configuration (true/false)
VITE_ENABLE_ANALYTICS=true
VITE_LOG_LEVEL=info
